# Copia in .env.local e compila con i valori reali (NON committare .env.local).

# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Nuovo formato chiavi: "publishable key" (sb_publishable_...). Il client la usa
# nella stessa posizione della vecchia anon key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
# Segreto admin (server-side, bypassa RLS). Non necessario per l'onboarding.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App ────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost:3000
# Anteprima UI autenticata senza login (solo dev): 1 = on, 0 = off
NEXT_PUBLIC_DEMO=0

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx

# ─── Stripe ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
